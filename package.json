{
  "name": "dedrive",
  "version": "1.0.0",
  "description": "Private Google Drive duplicate finder with read-only scanning and safe cleanup into a _dupes folder.",
  "packageManager": "pnpm@10.27.0",
  "main": "index.js",
  "scripts": {
    "preinstall": "node -e \"const ua = process.env.npm_config_user_agent || ''; if (!ua.startsWith('pnpm/')) { console.error('Use pnpm for this repo.'); process.exit(1); }\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsilva/dedrive.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/tsilva/dedrive/issues"
  },
  "homepage": "https://github.com/tsilva/dedrive#readme",
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "next": "^16.2.3",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
