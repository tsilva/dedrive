  "metadata": {
    "title": "dedrive | Secure Google Drive Duplicate Finder & Cleaner",
    "short_description": "A private, client-side web app to identify and move duplicate files in Google Drive using MD5 checksums. Reclaim storage space without your data leaving the browser.",
    "social_title": "dedrive - Clean up Google Drive Duplicates Privately",
    "social_description": "Scan your Google Drive for duplicate files with MD5 checksum verification. Secure, 100% client-side, and non-destructive cleanup.",
    "keywords": [
      "Google Drive",
      "Duplicate Finder",
      "MD5 Checksum",
      "Next.js",
      "Storage Cleanup",
      "Privacy-focused",
      "Client-side",
      "Drive API",
      "File Deduplication",
      "Node.js"
    ]
  },
